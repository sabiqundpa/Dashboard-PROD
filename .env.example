# Pooled connection (used at runtime). Use connection_limit >= 9 so the
# 7 concurrent dashboard requests (kpi/machines/breakdowns/pareto/
# pareto-machines/downtime-by-day/mtbf-mttr-trend) don't starve each other
# waiting on too few pooled connections.
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true&connection_limit=9"

# Direct (non-pooled) connection, used for migrations.
DIRECT_URL="postgresql://user:password@host:5432/dbname"

PORT=3001

# Secret used to sign admin login JWTs - keep this private
JWT_SECRET="change-me-to-a-long-random-string"
