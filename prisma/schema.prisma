generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("maintenance") // maintenance | produksi
  createdAt    DateTime @default(now())
}

// Master data relasional — dikelola lewat menu "Master Data" di dashboard
// (bukan lagi lewat Supabase Table Editor langsung, supaya relasinya utuh).
// Alur: Group Head → Cluster → Part Name (+ Cycle Time) → Proses
// (+ Line Produksi, Mesin, Man Power). Waktu Efektif tetap input manual.
model MasterCluster {
  id      Int    @id @default(autoincrement())
  cluster String @map("CLUSTER")

  @@map("CLUSTER")
}

// 1 Group Head → 1 Cluster.
model MasterGroupHead {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  cluster   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("MasterGroupHead")
}

// 1 Cluster → banyak Part Name. Tiap Part Name punya 1 Cycle Time standar.
model MasterPartName {
  id        Int      @id @default(autoincrement())
  partName  String   @unique @map("part_name")
  cluster   String
  cycleTime Float    @default(0) @map("cycle_time")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("MasterPartName")
}

// 1 Part Name → banyak Proses. Tiap Proses terhubung ke 1 Line Produksi,
// 1 Mesin, dan 1 Man Power.
model MasterProses {
  id        Int      @id @default(autoincrement())
  proses    String
  partName  String   @map("part_name")
  line      String   @map("line_produksi")
  mesin     String
  manPower  String   @map("man_power")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([proses, partName])
  @@map("MasterProses")
}

// Resume Control Harian Produksi — satu baris per Part + Proses + Mesin per
// hari/shift, diisi via halaman /rmo (form publik tanpa login).
// Struktur & rumus AR/AVB/PERF/YIELD/OEE mengikuti format Excel existing.
model ProduksiHarian {
  id             Int      @id @default(autoincrement())
  tanggal        DateTime
  waktu          String?                                        // jam input, format HH:MM
  shift          String
  cluster        String
  line           String   @map("line_produksi")
  grupHead       String?  @map("grup_head")

  noLot          String?  @map("no_lot")
  partName       String   @map("part_name")
  partNumber     String?  @map("part_number")
  proses         String
  mesin          String
  manPower       String?  @map("man_power")
  cycleTime      Float    @default(0) @map("cycle_time")       // detik/pcs
  waktuEfektif   Float    @default(0) @map("waktu_efektif")    // jam
  plan           Int      @default(0)

  ok1            Int      @default(0)
  ok2            Int      @default(0)
  rework         Int      @default(0) @map("rwk")
  reject         Int      @default(0) @map("rjct")

  breakdownMesin Float    @default(0) @map("breakdown_mesin")  // menit
  lostTime       Float    @default(0) @map("lost_time")        // menit
  keterangan     String?

  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ProduksiHarian")
}

// Log problem/root-cause untuk kasus AR/produksi rendah — ditampilkan di
// halaman detail AR (tabel Problem, Root Cause, Temporary/Permanent Action).
model ProblemLog {
  id                Int       @id @default(autoincrement())
  tanggal           DateTime? // tanggal produksi saat problem terjadi (ikut form RC Harian)
  line              String?   @map("line_produksi")
  partName          String?   @map("part_name")
  problem           String
  rootCause         String?   @map("root_cause")
  temporaryAction   String?   @map("temporary_action")
  permanentAction   String?   @map("permanent_action")
  dueDate           DateTime? @map("due_date")
  status            String    @default("open") // open | in_progress | closed
  notes             String?
  closedAt          DateTime? @map("closed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@map("ProblemLog")
}
